# Wähle den Storage-Typ: "webdav" oder "onedrive"
STORAGE__TYPE=webdav

# --- WebDAV (Nextcloud, ownCloud, etc.) ---
WEBDAV__URL=https://dein-nextcloud.de/remote.php/dav/files/USERNAME/journal.md
WEBDAV__USERNAME=dein-nutzer
WEBDAV__PASSWORD=dein-passwort

# --- OneDrive (Microsoft Graph) ---
# App registrieren: https://portal.azure.com → App-Registrierungen
# Benötigte Berechtigungen: Files.ReadWrite, offline_access (delegiert)
# Ersten Refresh Token holen: http://localhost:8080/auth/onedrive/login
ONEDRIVE__CLIENTID=
ONEDRIVE__CLIENTSECRET=
ONEDRIVE__REFRESHTOKEN=
ONEDRIVE__FILEPATH=journal.md
ONEDRIVE__TENANT=consumers
